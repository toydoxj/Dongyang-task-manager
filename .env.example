# ==========================================
# 백엔드 (FastAPI)
# ==========================================
# JWT 시크릿 (운영 시 안전하게 생성: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SQLite 경로 (Electron 패키징 시에는 userData 경로로 오버라이드)
DATABASE_URL=sqlite:///./data/app.db

# 백엔드 바인드
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ==========================================
# 노션 API
# ==========================================
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_MEMBERS=
NOTION_DB_PROJECTS=
NOTION_DB_TASKS=
NOTION_DB_ACTIVITY_LOG=
NOTION_DB_UTILITIES=

# ==========================================
# 프론트엔드 (Next.js)
# ==========================================
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# ==========================================
# Electron
# ==========================================
ELECTRON_DEV_URL=http://localhost:3000
