# 백엔드 환경변수 — 로컬 dev 용 .env 작성 시 참고
# 운영(Render): Render Dashboard에서 Environment에 직접 등록 (이 파일은 비밀 보관 X)

# Postgres (Supabase pooled URI 권장, port 6543)
# 로컬에서 sqlite로 dev하려면 sqlite:///./data/app.db
DATABASE_URL=postgres://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=replace-with-32+chars-random
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Notion API
NOTION_API_KEY=secret_xxx
NOTION_DB_PROJECTS=
NOTION_DB_TASKS=
NOTION_DB_CASHFLOW=
NOTION_DB_EXPENSE=
NOTION_DB_ASSIGN_LOG=
NOTION_DB_CLIENTS=
NOTION_DB_MASTER=
NOTION_DB_SUGGESTIONS=
NOTION_DB_SEAL_REQUESTS=
NOTION_DB_CONTRACT_ITEMS=
NOTION_DB_SALES=


# CORS — 콤마 구분 (Vercel 도메인 + 로컬). cookie 인증과 함께 쓰려면 `*` 금지.
CORS_ORIGINS=https://task.dyce.kr,http://localhost:3000

# JWT cookie (Phase 4-G 1단계 점진 마이그레이션)
# 운영 default: cookie_secure=true / cookie_samesite=strict (env 미설정 시 자동 적용).
#   sub-domain 공유가 필요하면 COOKIE_DOMAIN=.dyce.kr 만 추가 입력.
# dev(localhost http): 아래 3개를 명시 override 필수.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 노션 → Postgres 미러 sync 설정
SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=5

# 외부 cron 트리거 (POST /api/cron/sync) 인증 토큰
CRON_SECRET=replace-with-random-secret
